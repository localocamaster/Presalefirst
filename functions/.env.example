# Firebase Console > Functions > sendInquiryEmail > 환경 변수 설정
# Gmail 사용 시: 앱 비밀번호 생성 필요 (2단계 인증 활성화 후)

# SMTP 설정 (Gmail 기본값)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password

# 문의 수신 이메일 (미설정 시 SMTP_USER로 발송)
INQUIRY_TO_EMAIL=localoca.master@gmail.com
